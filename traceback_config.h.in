/*
 * Generated by CMake from traceback_config.h.in. This is the standalone
 * library's own option header: it replaces Xapiand's project-wide "config.h",
 * which traceback.cc used solely for the XAPIAND_TRACEBACKS gate. The library
 * owns the options as CMake cache variables (both default OFF); CMake emits each
 * macro definition below only when its option is ON.
 *
 * TRACEBACK_HOOKS builds the crash dumper: the fixed, multi-megabyte, lock-free
 * thread registry, the SIGUSR2 stack-walk handler, and the all-thread
 * dump_callstacks()/snapshot(). It leaves the process allocator untouched.
 *
 * TRACEBACK_THROW_HOOKS builds the throw-site tracker: the __cxa_throw +
 * malloc/calloc/realloc/free interposition that records throw-site callstacks.
 * It is a separate opt-in because that allocator override is a landmine; a host
 * can take the dumper without it.
 *
 * With both OFF (the default) NONE of that is built: the library is just the
 * lightweight formatting box (capture/describe/format) plus backtrace().
 *
 * TRACEBACK_MAX_THREADS sizes the registry array, TRACEBACK_MAX_FRAMES sizes
 * each slot's per-thread callstack; both only matter under TRACEBACK_HOOKS.
 *
 * A FetchContent consumer that populates the sources without running this
 * library's CMake will not get this file; traceback.cc guards its inclusion on
 * __has_include, so such a consumer can instead -D these on its own compile
 * line.
 *
 * Do not edit by hand. Edit traceback_config.h.in and re-run CMake.
 */

#pragma once

#cmakedefine TRACEBACK_HOOKS 1
#cmakedefine TRACEBACK_THROW_HOOKS 1

#cmakedefine TRACEBACK_MAX_THREADS @TRACEBACK_MAX_THREADS@
#cmakedefine TRACEBACK_MAX_FRAMES @TRACEBACK_MAX_FRAMES@
