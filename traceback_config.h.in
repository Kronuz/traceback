/*
 * Generated by CMake from traceback_config.h.in. This is the standalone
 * library's own option header: it replaces Xapiand's project-wide "config.h",
 * which traceback.cc used solely for the XAPIAND_TRACEBACKS gate. The library
 * owns the option as the CMake cache variable TRACEBACK_HOOKS (default OFF);
 * CMake emits the macro definition below only when it is ON.
 *
 * When TRACEBACK_HOOKS is defined, the heavy interposition path compiles in: a
 * __cxa_throw override that records the throw-site callstack, and global
 * malloc/calloc/realloc/free overrides that reserve a slot for it. With it OFF
 * (the default) the all-thread signal snapshot and the per-thread formatter
 * still work; only the throw-site capture is absent.
 *
 * A FetchContent consumer that populates the sources without running this
 * library's CMake will not get this file; traceback.cc guards its inclusion on
 * __has_include, so such a consumer can instead -DTRACEBACK_HOOKS on its own
 * compile line.
 *
 * Do not edit by hand. Edit traceback_config.h.in and re-run CMake.
 */

#pragma once

#cmakedefine TRACEBACK_HOOKS 1
